{
  "name": "futura",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "futura-api",
    "futura-web"
  ],
  "scripts": {
    "dev:api": "npm --workspace futura-api run dev",
    "deploy:api": "npm --workspace futura-api run deploy",
    "dev:web": "npm --workspace futura-web run dev",
    "build:web": "npm --workspace futura-web run build",
    "start:web": "npm --workspace futura-web run start",
    "build:static": "node scripts/write-seo-files.js && tailwindcss -i ./css/tailwind.input.css -o ./css/app.css --minify",
    "build:css": "npm run build:static",
    "watch:static": "tailwindcss -i ./css/tailwind.input.css -o ./css/app.css --watch",
    "dev:static": "npm run watch:static"
  },
  "dependencies": {
    "cors": "^2.8.6"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.9",
    "tailwindcss": "^3.4.17"
  }
}
